# Google OAuth (Google Cloud Console에서 발급)
# Authorized redirect URI로 http://localhost:8000/auth/callback 등록 필요
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# 세션 시크릿 (긴 랜덤 문자열 — 발급: openssl rand -hex 32)
SESSION_SECRET=

# OAuth 허용 도메인 (학교 도메인)
ALLOWED_EMAIL_DOMAIN=hafs.hs.kr

# 관리자 이메일 (쉼표로 구분 — 도메인 제한 없이 로그인 허용)
ADMIN_EMAILS=admin@example.com

# 콜백 URL (Google Cloud Console에 등록된 거랑 일치해야 함)
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
